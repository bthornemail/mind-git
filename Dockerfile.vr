FROM node:18-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./
COPY logos-system/package*.json ./logos-system/

# Install dependencies
RUN npm ci

# Copy source code
COPY . .

# Build the project
RUN npm run build

# Install VR dependencies
RUN npm install @types/three @types/aframe @types/webrtc three aframe

# Expose ports
EXPOSE 3000 8080

# Create directories for canvases and knowledge
RUN mkdir -p /app/canvases /app/knowledge

# Start command
CMD ["npm", "run", "start"]